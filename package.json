{
  "name": "keynotes",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "db:start": "docker compose -f db/docker-compose.yml up -d postgres",
    "db:stop": "docker compose -f db/docker-compose.yml stop postgres",
    "db:remove": "docker compose -f db/docker-compose.yml down -v postgres",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "zero:dev": "zero-cache-dev",
    "zero:generate-schema": "drizzle-zero generate -f --suppress-defaults-warning -o src/zero/schema.ts"
  },
  "dependencies": {
    "@rocicorp/zero": "^1.0.0",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "@tanstack/solid-devtools": "^0.7.33",
    "@tanstack/solid-hotkeys": "^0.4.1",
    "@tanstack/solid-hotkeys-devtools": "^0.4.1",
    "@types/pg": "^8.20.0",
    "cally": "^0.9.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "lucide-solid": "^1.16.0",
    "pg": "^8.20.0",
    "solid-js": "^1.9.5",
    "uuid": "^13.0.0",
    "vinxi": "^0.5.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.7",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "drizzle-zero": "^0.18.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.0.7",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=22"
  }
}
